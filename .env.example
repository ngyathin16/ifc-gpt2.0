# LLM — Azure Responses API (gpt-5.4-pro)
# The endpoint must be the FULL Responses API URL including api-version query string.
# The custom AzureResponsesChatModel POSTs directly to this URL.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-pro

OPENAI_API_KEY=           # fallback if no Azure

# Supabase
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-side only
SUPABASE_JWT_SECRET=

# App
FRONTEND_ORIGIN=http://localhost:3000
WORKSPACE_DIR=./workspace
IDS_DIR=./validation/ids
